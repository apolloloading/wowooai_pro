{
  "site_id": "qd_system",
  "system_name": "QD系统(外包管理系统)",
  "host_patterns": [
    "qd-system*.renliwo.com"
  ],
  "default_base_url": "https://qd-system-front-demo.renliwo.com",
  "routing": {
    "type": "path",
    "hash_prefix": null
  },
  "login": {
    "url_path": "/user/login",
    "username_selector": "#username",
